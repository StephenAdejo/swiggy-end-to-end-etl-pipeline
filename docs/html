    .btn {
      font-family: var(--mono);
      font-size: 12px;
      letter-spacing: .04em;
      padding: 11px 22px;
      border-radius: 3px;
      text-decoration: none;
      cursor: pointer;
      border: 1px solid;
      transition: background .15s, color .15s;
