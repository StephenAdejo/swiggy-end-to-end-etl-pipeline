  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --ink: #0e0e0e;
      --paper: #f7f5f0;
      --mid: #e2ddd5;
      --accent: #1a1a2e;
      --gold: #c8a84b;
      --dim: #6e6858;
      --white: #ffffff;
      --green: #2a7a2a;
      --mono: 'DM Mono', monospace;
      --serif: 'DM Serif Display', serif;
      --sans: 'Outfit', sans-serif;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--paper);
      color: var(--ink);
      font-family: var(--sans);
      font-weight: 400;
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }

    /* ── LAYOUT ── */
    .site { max-width: 920px; margin: 0 auto; padding: 0 32px 100px; }

    /* ── NAV ── */
    nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 24px 0 20px;
      border-bottom: 1px solid var(--mid);
      position: sticky;
      top: 0;
      background: var(--paper);
      z-index: 10;
    }
    .nav-brand { font-family: var(--mono); font-size: 12px; color: var(--dim); letter-spacing: .04em; }
    .nav-brand a { color: inherit; text-decoration: none; }
    .nav-links { display: flex; gap: 24px; }
    .nav-links a {
      font-size: 12px;
      color: var(--dim);
      text-decoration: none;
      font-family: var(--mono);
      letter-spacing: .03em;
      transition: color .15s;
    }
    .nav-links a:hover { color: var(--ink); }

    /* ── HERO ── */
    .hero { padding: 72px 0 56px; border-bottom: 1px solid var(--mid); }
    .hero-tag {
      font-family: var(--mono);
      font-size: 11px;
      color: var(--gold);
      letter-spacing: .14em;
      text-transform: uppercase;
      margin-bottom: 24px;
    }
    .hero h1 {
      font-family: var(--serif);
      font-size: clamp(38px, 6vw, 60px);
      line-height: 1.08;
      margin-bottom: 24px;
      color: var(--ink);
    }
    .hero h1 em { font-style: italic; color: var(--dim); }
    .hero-desc {
      font-size: 17px;
      color: var(--dim);
      max-width: 580px;
      line-height: 1.8;
      margin-bottom: 36px;
    }
    .hero-meta { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 32px; }
    .meta-pill {
      font-family: var(--mono);
      font-size: 11px;
      color: var(--dim);
      background: var(--mid);
      padding: 5px 13px;
      border-radius: 2px;
      letter-spacing: .04em;
    }
    .meta-pill.active { background: var(--accent); color: #fff; }

    /* ── STATUS BAR ── */
    .status-bar {
      padding: 16px 22px;
      background: var(--accent);
      border-radius: 4px;
      display: flex;
      align-items: center;
      gap: 14px;
    }
    .status-dot {
      width: 8px; height: 8px;
      border-radius: 50%;
      background: #4ade80;
      flex-shrink: 0;
      animation: pulse 2.4s ease-in-out infinite;
    }
    @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: .3; } }
    .status-text { font-family: var(--mono); font-size: 12px; color: rgba(255,255,255,.65); }
    .status-text strong { color: #fff; }

    /* ── SECTIONS ── */
    .section { padding: 64px 0 0; }
    .section-label {
      font-family: var(--mono);
      font-size: 10px;
      color: var(--gold);
      letter-spacing: .14em;
      text-transform: uppercase;
      margin-bottom: 6px;
    }
    .section-title {
      font-family: var(--serif);
      font-size: 30px;
      color: var(--ink);
      margin-bottom: 8px;
    }
    .section-sub { font-size: 15px; color: var(--dim); margin-bottom: 36px; }

    /* ── PIPELINE ── */
    .pipeline-wrap { overflow-x: auto; padding-bottom: 4px; margin: 8px 0 32px; }
    .pipeline {
      display: flex;
      align-items: stretch;
      min-width: 560px;
    }
    .pipe-step {
      flex: 1;
      padding: 16px 10px;
      background: var(--white);
      border: 1px solid var(--mid);
      text-align: center;
      position: relative;
    }
    .pipe-step:not(:first-child) { border-left: none; }
    .pipe-step:first-child { border-radius: 4px 0 0 4px; }
    .pipe-step:last-child { border-radius: 0 4px 4px 0; }
    .pipe-step::after {
      content: '→';
      position: absolute;
      right: -10px;
      top: 50%;
      transform: translateY(-50%);
      font-size: 14px;
      color: var(--mid);
      z-index: 1;
      background: var(--white);
      padding: 0 2px;
    }
    .pipe-step:last-child::after { display: none; }
    .pipe-num { font-family: var(--mono); font-size: 10px; color: var(--gold); margin-bottom: 5px; }
    .pipe-name { font-family: var(--mono); font-size: 12px; font-weight: 500; color: var(--ink); }
    .pipe-table { font-size: 10px; color: var(--dim); margin-top: 5px; }

    /* ── STAT GRID ── */
    .stat-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
      gap: 12px;
      margin: 12px 0 0;
    }
    .stat-card {
      background: var(--white);
      border: 1px solid var(--mid);
      border-radius: 4px;
      padding: 20px;
    }
    .stat-label {
      font-family: var(--mono);
      font-size: 10px;
      color: var(--dim);
      letter-spacing: .06em;
      text-transform: uppercase;
      margin-bottom: 8px;
    }
    .stat-value { font-family: var(--serif); font-size: 32px; color: var(--ink); }
    .stat-note { font-size: 12px; color: var(--dim); margin-top: 5px; }

    /* ── ORIGIN STORY ── */
    .callout {
      border-left: 3px solid var(--gold);
      padding: 20px 24px;
      background: var(--white);
      border-radius: 0 4px 4px 0;
      margin: 24px 0;
    }
    .callout p { font-size: 15px; color: var(--dim); line-height: 1.8; }
    .callout p strong { color: var(--ink); font-weight: 500; }

    /* ── DECISIONS ── */
    .decisions { list-style: none; margin: 8px 0; }
    .decisions li {
      padding: 20px 0;
      border-bottom: 1px solid var(--mid);
      display: grid;
      grid-template-columns: 160px 1fr;
      gap: 28px;
      align-items: start;
    }
    .decisions li:last-child { border-bottom: none; }
    .dec-key { font-family: var(--mono); font-size: 11px; color: var(--gold); padding-top: 2px; }
    .dec-val { font-size: 14px; color: var(--dim); line-height: 1.75; }
    .dec-val strong { color: var(--ink); font-weight: 500; }

    /* ── COMPARE TABLE ── */
    .compare-wrap { overflow-x: auto; margin: 12px 0; }
    .compare {
      width: 100%;
      border-collapse: collapse;
      font-size: 13px;
      min-width: 480px;
    }
    .compare th {
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: .06em;
      text-transform: uppercase;
      color: var(--dim);
      border-bottom: 1px solid var(--mid);
      padding: 10px 14px;
      text-align: left;
      font-weight: 500;
      background: var(--white);
    }
    .compare td {
      padding: 11px 14px;
      border-bottom: 1px solid var(--mid);
      color: var(--dim);
      background: var(--white);
    }
    .compare td:first-child { font-weight: 500; color: var(--ink); font-size: 12px; }
    .compare .better { color: var(--green); font-weight: 500; }
    .compare tr:last-child td { border-bottom: none; }

    /* ── IMAGE PLACEHOLDERS ── */
    .img-placeholder {
      background: var(--white);
      border: 1.5px dashed var(--mid);
      border-radius: 4px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 10px;
      padding: 48px 32px;
      margin: 16px 0;
      color: var(--dim);
      text-align: center;
    }
    .img-placeholder .ph-label {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: .08em;
      text-transform: uppercase;
      color: var(--dim);
    }
    .img-placeholder .ph-hint { font-size: 12px; color: var(--mid); }
    .ph-icon { font-size: 32px; opacity: .25; }

    /* ── ROADMAP ── */
    .roadmap {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
      margin: 12px 0;
    }
    @media (max-width: 560px) { .roadmap { grid-template-columns: 1fr; } }
    .rm-card {
      background: var(--white);
      border: 1px solid var(--mid);
      border-radius: 4px;
      padding: 20px 22px;
    }
    .rm-title {
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: .1em;
      text-transform: uppercase;
      margin-bottom: 14px;
    }
    .rm-title.done { color: var(--green); }
    .rm-title.progress { color: var(--gold); }
    .rm-title.planned { color: var(--dim); }
    .rm-section-gap { margin-top: 20px; }
    .rm-item {
      font-size: 13px;
      color: var(--dim);
      padding: 5px 0 5px 16px;
      position: relative;
      line-height: 1.5;
    }
    .rm-item::before {
      content: '';
      position: absolute;
      left: 0; top: 11px;
      width: 6px; height: 6px;
      border-radius: 50%;
    }
    .rm-item.done::before { background: var(--green); }
    .rm-item.progress::before { background: var(--gold); }
    .rm-item.planned::before { background: transparent; border: 1.5px solid var(--mid); }

    /* ── TECH STACK ── */
